# WhatsApp / Meta Cloud API
WA_TOKEN=
WA_PHONE_ID=
WEBHOOK_VERIFY_TOKEN=
WA_API_VERSION=v17.0

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Base de datos (PostgreSQL / Supabase)
# DB_HOST admite "host" o "host:puerto"; si trae puerto, tiene prioridad sobre DB_PORT.
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=5432
DB_NAME=

# Opcional (solo desarrollo / túnel local)
NGROK_AUTH_TOKEN=

# Rutas de recursos (opcional)
BASEPROMPT_XML_PATH=
CSV_COTIZACIONES_PDF=cotizaciones_pdf.csv

# Directorio de CSVs del sistema Argos (opcional)
ARGOS_DIR=
